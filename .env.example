# --- Required (no real values in repo) ---
POSTGRES_URI=<POSTGRES_CONNECTION_STRING>
MONGO_URI=<MONGO_CONNECTION_STRING>
MONGO_DB=<DATABASE_NAME>
MONGO_COLLECTION=<MONGO_COLLECTION_NAME>
SYNC_CONFIG=./sync_videos.json

# --- Environment / guardrails ---
# dev|staging|prod
APP_ENV=dev
# Required to run when APP_ENV=prod (guardrail)
ALLOW_PROD_SYNC=false

# --- Optional operational controls ---
# If not set, the script uses "yesterday UTC"
# Format: YYYY-MM-DD
# SYNC_DATE=2026-01-04

# Timeouts (ms)
STATEMENT_TIMEOUT_MS=120000
FRAMES_TIMEOUT_MS=8000
MONGO_TIMEOUT_MS=10000
PG_CONN_TIMEOUT_MS=10000
PG_IDLE_TIMEOUT_MS=30000

# Pool sizing (batch job)
PG_MAX_CLIENTS=5
